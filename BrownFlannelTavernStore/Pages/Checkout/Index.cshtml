@page
@model BrownFlannelTavernStore.Pages.Checkout.IndexModel
@using BrownFlannelTavernStore.Models
@{
    ViewData["Title"] = "Checkout";
}

<h2>Checkout</h2>

@if (!Model.CartItems.Any())
{
    <p>Your cart is empty.</p>
    <a asp-page="/Products/Index" class="btn btn-bft">Continue Shopping</a>
}
else
{
    <div class="row">
        <div class="col-md-7">
            <h4>Fulfillment</h4>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <form method="post" id="payment-form">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input fulfillment-radio" type="radio" name="FulfillmentMethod"
                               id="fulfillment-shipped" value="Shipped"
                               checked="@(Model.FulfillmentMethod == FulfillmentMethod.Shipped)" />
                        <label class="form-check-label" for="fulfillment-shipped">
                            Ship to my address
                        </label>
                    </div>
                    @if (BusinessOptions.Value.Pickup.Enabled)
                    {
                        <div class="form-check">
                            <input class="form-check-input fulfillment-radio" type="radio" name="FulfillmentMethod"
                                   id="fulfillment-pickup" value="Pickup"
                                   checked="@(Model.FulfillmentMethod == FulfillmentMethod.Pickup)" />
                            <label class="form-check-label" for="fulfillment-pickup">
                                Pick up at the @BusinessOptions.Value.Pickup.LocationName
                            </label>
                        </div>
                    }
                </div>

                <h4>Contact Information</h4>
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input asp-for="CustomerName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="CustomerEmail" type="email" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone <span class="text-muted">(optional)</span></label>
                    <input asp-for="Phone" type="tel" class="form-control" />
                </div>

                <div id="shipping-section">
                    <h4 class="mt-4">Shipping Address</h4>
                    <div class="mb-3">
                        <label class="form-label">Address</label>
                        <input asp-for="ShippingAddress" class="form-control tax-trigger" />
                        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">City</label>
                            <input asp-for="City" class="form-control tax-trigger" />
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">State</label>
                            <input asp-for="State" class="form-control tax-trigger" />
                            <span asp-validation-for="State" class="text-danger"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Zip Code</label>
                            <input asp-for="ZipCode" class="form-control tax-trigger" />
                            <span asp-validation-for="ZipCode" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div id="pickup-info" class="alert alert-info d-none">
                    <strong>Pick up at the @BusinessOptions.Value.Pickup.LocationName</strong><br />
                    @BusinessOptions.Value.Pickup.FormattedAddress()<br />
                    <small>Hours: @BusinessOptions.Value.Pickup.Hours</small>
                    @if (!string.IsNullOrWhiteSpace(BusinessOptions.Value.Pickup.Instructions))
                    {
                        <br />
                        <small>@BusinessOptions.Value.Pickup.Instructions</small>
                    }
                    <hr class="my-2" />
                    You will be notified when your order is ready for pickup.
                </div>

                <h4 class="mt-4">Payment</h4>
                <div id="card-element" class="form-control mb-3 pt-2">
                    <!-- Stripe Elements will mount here -->
                </div>
                <div id="card-errors" class="text-danger mb-3" role="alert"></div>

                <input type="hidden" asp-for="PaymentIntentId" id="payment-intent-id" />
                <input type="hidden" name="stripePaymentMethodId" id="stripe-payment-method-id" />

                <button type="submit" id="submit-button" class="btn btn-bft btn-lg w-100">
                    Pay $<span id="submit-total">@Model.Subtotal.ToString("F2")</span>
                </button>
            </form>
        </div>
        <div class="col-md-5">
            <h4>Order Summary</h4>
            <ul class="list-group mb-3">
                @foreach (var item in Model.CartItems)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <div>
                            <span>@item.ProductName</span>
                            <small class="text-muted d-block">@item.Size @item.Color x @item.Quantity</small>
                        </div>
                        <span>$@item.Total.ToString("F2")</span>
                    </li>
                }
                <li class="list-group-item d-flex justify-content-between">
                    <span>Subtotal</span>
                    <span id="summary-subtotal">$@Model.Subtotal.ToString("F2")</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>Tax</span>
                    <span id="summary-tax" class="text-muted">—</span>
                </li>
                <li class="list-group-item d-flex justify-content-between fw-bold">
                    <span>Total</span>
                    <span id="summary-total">$@Model.Subtotal.ToString("F2")</span>
                </li>
            </ul>
            <div id="tax-status" class="small text-muted">Enter your address to calculate tax.</div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://js.stripe.com/v3/"></script>
    <script>
        const stripe = Stripe('@Model.StripePublishableKey');
        const elements = stripe.elements();
        const cardElement = elements.create('card');
        cardElement.mount('#card-element');

        cardElement.on('change', function (event) {
            const displayError = document.getElementById('card-errors');
            displayError.textContent = event.error ? event.error.message : '';
        });

        const shippingSection = document.getElementById('shipping-section');
        const pickupInfo = document.getElementById('pickup-info');
        const fulfillmentRadios = document.querySelectorAll('.fulfillment-radio');
        const summarySubtotal = document.getElementById('summary-subtotal');
        const summaryTax = document.getElementById('summary-tax');
        const summaryTotal = document.getElementById('summary-total');
        const submitTotal = document.getElementById('submit-total');
        const taxStatus = document.getElementById('tax-status');
        const paymentIntentId = '@Model.PaymentIntentId';

        let currentTotal = @Model.Subtotal.ToString("F2");
        let taxCalculated = false;

        function getSelectedFulfillment() {
            return document.querySelector('.fulfillment-radio:checked').value;
        }

        function updateFulfillmentVisibility() {
            const selected = getSelectedFulfillment();
            if (selected === 'Pickup') {
                shippingSection.classList.add('d-none');
                pickupInfo.classList.remove('d-none');
            } else {
                shippingSection.classList.remove('d-none');
                pickupInfo.classList.add('d-none');
            }
        }

        fulfillmentRadios.forEach(radio => radio.addEventListener('change', () => {
            updateFulfillmentVisibility();
            recalcTax();
        }));
        updateFulfillmentVisibility();

        function fmt(amount) {
            return '$' + Number(amount).toFixed(2);
        }

        async function recalcTax() {
            const fulfillment = getSelectedFulfillment();
            const payload = {
                paymentIntentId: paymentIntentId,
                fulfillmentMethod: fulfillment,
                addressLine1: document.querySelector('[name="ShippingAddress"]').value,
                city: document.querySelector('[name="City"]').value,
                state: document.querySelector('[name="State"]').value,
                zipCode: document.querySelector('[name="ZipCode"]').value,
            };

            if (fulfillment === 'Shipped' && (!payload.addressLine1 || !payload.city || !payload.state || !payload.zipCode)) {
                taxStatus.textContent = 'Enter your address to calculate tax.';
                return;
            }

            taxStatus.textContent = 'Calculating tax...';
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const response = await fetch('?handler=CalculateTax', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token,
                    },
                    body: JSON.stringify(payload),
                });
                if (!response.ok) {
                    const err = await response.json().catch(() => ({ error: 'Tax calculation failed.' }));
                    taxStatus.textContent = err.error || 'Tax calculation failed.';
                    return;
                }
                const data = await response.json();
                summarySubtotal.textContent = fmt(data.subtotal);
                summaryTax.textContent = fmt(data.tax);
                summaryTax.classList.remove('text-muted');
                summaryTotal.textContent = fmt(data.total);
                submitTotal.textContent = Number(data.total).toFixed(2);
                currentTotal = data.total;
                taxCalculated = true;
                taxStatus.textContent = '';
            } catch (e) {
                taxStatus.textContent = 'Tax calculation failed. Please try again.';
            }
        }

        document.querySelectorAll('.tax-trigger').forEach(el => {
            el.addEventListener('blur', recalcTax);
        });

        const form = document.getElementById('payment-form');
        form.addEventListener('submit', async function (event) {
            event.preventDefault();
            const submitButton = document.getElementById('submit-button');

            const fulfillment = getSelectedFulfillment();
            if (!taxCalculated && fulfillment === 'Shipped') {
                await recalcTax();
                if (!taxCalculated) {
                    document.getElementById('card-errors').textContent = 'Please enter a complete shipping address.';
                    return;
                }
            } else if (!taxCalculated && fulfillment === 'Pickup') {
                await recalcTax();
            }

            submitButton.disabled = true;
            submitButton.textContent = 'Processing...';

            const clientSecret = '@Model.ClientSecret';

            const { error, paymentIntent } = await stripe.confirmCardPayment(clientSecret, {
                payment_method: {
                    card: cardElement,
                    billing_details: {
                        name: document.querySelector('[name="CustomerName"]').value,
                        email: document.querySelector('[name="CustomerEmail"]').value,
                    }
                }
            });

            if (error) {
                document.getElementById('card-errors').textContent = error.message;
                submitButton.disabled = false;
                submitButton.textContent = 'Pay $' + Number(currentTotal).toFixed(2);
            } else if (paymentIntent.status === 'succeeded') {
                document.getElementById('stripe-payment-method-id').value = paymentIntent.payment_method;
                form.submit();
            }
        });
    </script>
}
