@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4">Welcome to the Brown Flannel Tavern Store</h1>
    <p class="lead">Gear up with our official tavern merchandise.</p>
    <a asp-page="/Products/Index" class="btn btn-lg btn-bft mt-3">Shop Now</a>
</div>

<div class="row mt-4">
    @foreach (var product in Model.FeaturedProducts)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                @if (!string.IsNullOrEmpty(product.ImageUrl))
                {
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 250px; object-fit: cover;" />
                }
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@product.Name</h5>
                    <p class="card-text">@product.Description</p>
                    <p class="card-text fw-bold mt-auto">$@product.Price.ToString("F2")</p>
                    <a asp-page="/Products/Details" asp-route-id="@product.Id" class="btn btn-outline-bft">View Details</a>
                </div>
            </div>
        </div>
    }
</div>
