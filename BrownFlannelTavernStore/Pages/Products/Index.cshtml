@page
@model BrownFlannelTavernStore.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Shop";
}

<h2>Shop</h2>

@if (Model.Categories.Any())
{
    <div class="mb-3">
        <a asp-page="/Products/Index" class="btn btn-sm @(string.IsNullOrEmpty(Model.SelectedCategory) ? "btn-bft" : "btn-outline-bft")">All</a>
        @foreach (var category in Model.Categories)
        {
            <a asp-page="/Products/Index" asp-route-category="@category"
               class="btn btn-sm @(Model.SelectedCategory == category ? "btn-bft" : "btn-outline-bft")">@category</a>
        }
    </div>
}

<div class="row">
    @foreach (var product in Model.Products)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                @if (!string.IsNullOrEmpty(product.ImageUrl))
                {
                    <img src="@product.ImageUrl" class="card-img-top product-thumbnail" alt="@product.Name" />
                }
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@product.Name</h5>
                    <p class="card-text text-muted">@product.Category</p>
                    <p class="card-text">@product.Description</p>
                    <p class="card-text fw-bold mt-auto">$@product.Price.ToString("F2")</p>
                    <a asp-page="/Products/Details" asp-route-id="@product.Id" class="btn btn-outline-bft">View Details</a>
                </div>
            </div>
        </div>
    }
</div>
