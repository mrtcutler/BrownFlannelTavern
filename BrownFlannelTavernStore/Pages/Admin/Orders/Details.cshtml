@page "{id:int}"
@model BrownFlannelTavernStore.Pages.Admin.Orders.DetailsModel
@using BrownFlannelTavernStore.Models
@{
    ViewData["Title"] = $"Order #{Model.Order?.Id}";
}

@if (Model.Order == null)
{
    <h2>Order not found.</h2>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Order #@Model.Order.Id</h2>
        <span class="badge bg-bft fs-6">@Model.Order.Status</span>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-success">@Model.Message</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header"><strong>Customer Information</strong></div>
                <div class="card-body">
                    <p><strong>Name:</strong> @Model.Order.CustomerName</p>
                    <p><strong>Email:</strong> @Model.Order.CustomerEmail</p>
                    @if (!string.IsNullOrWhiteSpace(Model.Order.Phone))
                    {
                        <p><strong>Phone:</strong> @Model.Order.Phone</p>
                    }
                    <p><strong>Fulfillment:</strong>
                        @if (Model.Order.FulfillmentMethod == FulfillmentMethod.Pickup)
                        {
                            <span class="badge bg-secondary">Pickup at store</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Ship to address</span>
                        }
                    </p>
                    @if (Model.Order.FulfillmentMethod == FulfillmentMethod.Shipped)
                    {
                        <p><strong>Address:</strong> @Model.Order.ShippingAddress</p>
                        <p>@Model.Order.City, @Model.Order.State @Model.Order.ZipCode</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header"><strong>Order Info</strong></div>
                <div class="card-body">
                    <p><strong>Date:</strong> @Model.Order.CreatedAt.ToString("MM/dd/yyyy h:mm tt")</p>
                    @if (Model.Order.UpdatedAt.HasValue)
                    {
                        <p><strong>Last Updated:</strong> @Model.Order.UpdatedAt.Value.ToString("MM/dd/yyyy h:mm tt")</p>
                    }
                    <p><strong>Stripe Payment ID:</strong> <code>@Model.Order.StripePaymentIntentId</code></p>
                    <p><strong>Total:</strong> $@Model.Order.TotalAmount.ToString("F2")</p>
                </div>
            </div>
        </div>
    </div>

    <h4>Items</h4>
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Size / Color</th>
                <th>Unit Price</th>
                <th>Qty</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var line in Model.Order.Lines)
            {
                <tr>
                    <td>@line.ProductName</td>
                    <td>@line.Size @(line.Color != null ? $"/ {line.Color}" : "")</td>
                    <td>$@line.UnitPrice.ToString("F2")</td>
                    <td>@line.Quantity</td>
                    <td>$@((line.UnitPrice * line.Quantity).ToString("F2"))</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="4" class="text-end fw-bold">Total:</td>
                <td class="fw-bold">$@Model.Order.TotalAmount.ToString("F2")</td>
            </tr>
        </tfoot>
    </table>

    <hr />

    <h4>Update Order</h4>
    <form method="post" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select asp-for="NewStatus" class="form-select">
                @foreach (var status in BrownFlannelTavernStore.Pages.Admin.Orders.DetailsModel.ManuallyAssignableStatuses)
                {
                    <option value="@status" selected="@(status == Model.Order.Status)">@status</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">Notes</label>
            <input asp-for="OrderNotes" class="form-control" value="@Model.Order.Notes" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-bft">Update Order</button>
        </div>
    </form>

    @if (Model.CanRefund)
    {
        <hr />
        <h4>Refund</h4>
        <p class="text-muted small">
            Issuing a refund returns <strong>$@Model.Order.TotalAmount.ToString("F2")</strong> to the customer's original payment method via Stripe and marks this order as Refunded. This cannot be undone.
        </p>
        <button type="button" class="btn btn-danger"
                data-bs-toggle="modal" data-bs-target="#refundConfirmModal">
            Refund Order
        </button>

        <div class="modal fade" id="refundConfirmModal" tabindex="-1"
             aria-labelledby="refundConfirmModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="post" asp-page-handler="Refund">
                        <div class="modal-header">
                            <h5 class="modal-title" id="refundConfirmModalLabel">Confirm Refund</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p class="mb-3">
                                Refund <strong>$@Model.Order.TotalAmount.ToString("F2")</strong>
                                to <strong>@Model.Order.CustomerName</strong>?
                            </p>
                            <p class="text-muted small mb-0">
                                This refunds the full order via Stripe and cannot be undone. The customer will receive a refund confirmation email automatically.
                            </p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-danger">Refund Order</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
    else if (Model.Order.Status == OrderStatus.Refunded)
    {
        <hr />
        <h4>Refund</h4>
        <p class="text-muted">
            This order was refunded on @(Model.Order.RefundedAt?.ToString("MM/dd/yyyy h:mm tt") ?? "—").
            @if (!string.IsNullOrWhiteSpace(Model.Order.StripeRefundId))
            {
                <br />
                <span>Stripe refund ID: <code>@Model.Order.StripeRefundId</code></span>
            }
        </p>
    }

    @if (!string.IsNullOrEmpty(Model.Order.Notes))
    {
        <div class="mt-3">
            <strong>Current Notes:</strong>
            <p>@Model.Order.Notes</p>
        </div>
    }

    <div class="mt-4">
        <a asp-page="/Admin/Orders/Index" class="btn btn-outline-bft">Back to Orders</a>
    </div>
}
