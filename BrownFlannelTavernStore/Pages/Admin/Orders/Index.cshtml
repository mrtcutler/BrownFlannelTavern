@page
@model BrownFlannelTavernStore.Pages.Admin.Orders.IndexModel
@using BrownFlannelTavernStore.Models
@using BrownFlannelTavernStore.Utilities
@{
    ViewData["Title"] = "Manage Orders";

    SortableHeaderViewModel Sortable(string columnKey, string displayName) => new()
    {
        PageName = "/Admin/Orders/Index",
        ColumnKey = columnKey,
        DisplayName = displayName,
        CurrentSort = Model.SortBy,
        CurrentDir = Model.SortDir,
        RouteData = Model.BuildRouteData()
    };

    var idHeader = Sortable(OrdersSortKeys.Id, "Order #");
    var customerHeader = Sortable(OrdersSortKeys.Customer, "Customer");
    var totalHeader = Sortable(OrdersSortKeys.Total, "Total");
    var statusHeader = Sortable(OrdersSortKeys.Status, "Status");
    var dateHeader = Sortable(OrdersSortKeys.Date, "Date");
}

<h2>Manage Orders</h2>

<form method="get" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label small">Status</label>
            <select asp-for="StatusFilter" class="form-select form-select-sm">
                <option value="">All</option>
                @foreach (var s in Enum.GetValues<OrderStatus>())
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-1">
            <label class="form-label small">Order #</label>
            <input asp-for="OrderIdFilter" type="number" min="1" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Date from</label>
            <input asp-for="DateFromFilter" type="date" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Date to</label>
            <input asp-for="DateToFilter" type="date" class="form-control form-control-sm" />
        </div>
        <div class="col-md-3">
            <label class="form-label small">Customer (name or email)</label>
            <input asp-for="CustomerSearchFilter" type="text" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <input type="hidden" asp-for="SortBy" />
            <input type="hidden" asp-for="SortDir" />
            <button type="submit" class="btn btn-sm btn-bft">Apply</button>
            <a asp-page="/Admin/Orders/Index" class="btn btn-sm btn-outline-bft">Clear</a>
        </div>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <partial name="_SortableHeader" model="idHeader" />
            <partial name="_SortableHeader" model="customerHeader" />
            <th>Email</th>
            <partial name="_SortableHeader" model="totalHeader" />
            <partial name="_SortableHeader" model="statusHeader" />
            <partial name="_SortableHeader" model="dateHeader" />
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model.Orders.Items)
        {
            <tr>
                <td>@order.Id</td>
                <td>@order.CustomerName</td>
                <td>@order.CustomerEmail</td>
                <td>$@order.TotalAmount.ToString("F2")</td>
                <td><span class="badge bg-bft">@order.Status</span></td>
                <td>@order.CreatedAt.ToString("MM/dd/yyyy h:mm tt")</td>
                <td>
                    <a asp-page="/Admin/Orders/Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-bft">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_Pagination" model="@Model.Pagination" />

<a asp-page="/Admin/Index" class="btn btn-outline-bft mt-3">Back to Dashboard</a>
