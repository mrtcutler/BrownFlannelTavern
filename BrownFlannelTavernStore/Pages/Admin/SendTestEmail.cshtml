@page
@model BrownFlannelTavernStore.Pages.Admin.SendTestEmailModel
@{
    ViewData["Title"] = "Send Test Email";
}

<h2>Send Test Email</h2>
<p class="text-muted">Dev/debug utility — sends a one-off email through the configured Resend account to verify the integration.</p>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" class="col-md-8">
    <div class="mb-3">
        <label class="form-label">To</label>
        <input asp-for="To" type="email" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Subject</label>
        <input asp-for="Subject" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Body</label>
        <textarea asp-for="Body" class="form-control" rows="6" required></textarea>
    </div>
    <button type="submit" class="btn btn-bft">Send</button>
    <a asp-page="/Admin/Index" class="btn btn-outline-bft">Back to Dashboard</a>
</form>
