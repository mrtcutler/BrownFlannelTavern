@page
@model BrownFlannelTavernStore.Pages.Admin.Users.IndexModel
@using BrownFlannelTavernStore.Data
@using BrownFlannelTavernStore.Utilities
@{
    ViewData["Title"] = "Manage Users";

    SortableHeaderViewModel Sortable(string columnKey, string displayName) => new()
    {
        PageName = "/Admin/Users/Index",
        ColumnKey = columnKey,
        DisplayName = displayName,
        CurrentSort = Model.SortBy,
        CurrentDir = Model.SortDir,
        RouteData = Model.BuildRouteData()
    };

    var emailHeader = Sortable("email", "Email");
    var roleHeader = Sortable("role", "Role");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Users</h2>
    <a asp-page="/Admin/Users/Create" class="btn btn-bft">Add User</a>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<form method="get" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small">Role</label>
            <select asp-for="RoleFilter" class="form-select form-select-sm">
                <option value="">All</option>
                <option value="@SeedData.OwnerRole" selected="@(Model.RoleFilter == SeedData.OwnerRole)">@SeedData.OwnerRole</option>
                <option value="@SeedData.ManagerRole" selected="@(Model.RoleFilter == SeedData.ManagerRole)">@SeedData.ManagerRole</option>
            </select>
        </div>
        <div class="col-md-2">
            <input type="hidden" asp-for="SortBy" />
            <input type="hidden" asp-for="SortDir" />
            <button type="submit" class="btn btn-sm btn-bft">Apply</button>
            <a asp-page="/Admin/Users/Index" class="btn btn-sm btn-outline-bft">Clear</a>
        </div>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <partial name="_SortableHeader" model="emailHeader" />
            <partial name="_SortableHeader" model="roleHeader" />
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.AdminUsers.Items)
        {
            <tr>
                <td>@user.Email</td>
                <td><span class="badge bg-bft">@user.Role</span></td>
                <td>
                    @if (user.Email != User.Identity?.Name)
                    {
                        <a asp-page="/Admin/Users/Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-bft">Edit</a>
                        <form method="post" asp-page-handler="Delete" class="d-inline">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted">(You)</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_Pagination" model="@Model.Pagination" />

<a asp-page="/Admin/Index" class="btn btn-outline-bft mt-3">Back to Dashboard</a>
