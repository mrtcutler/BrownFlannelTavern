@page
@model BrownFlannelTavernStore.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Users</h2>
    <a asp-page="/Admin/Users/Create" class="btn btn-bft">Add User</a>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>Role</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.AdminUsers.Items)
        {
            <tr>
                <td>@user.Email</td>
                <td><span class="badge bg-bft">@user.Role</span></td>
                <td>
                    @if (user.Email != User.Identity?.Name)
                    {
                        <a asp-page="/Admin/Users/Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-bft">Edit</a>
                        <form method="post" asp-page-handler="Delete" class="d-inline">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted">(You)</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_Pagination" model="@Model.Pagination" />

<a asp-page="/Admin/Index" class="btn btn-outline-bft mt-3">Back to Dashboard</a>
