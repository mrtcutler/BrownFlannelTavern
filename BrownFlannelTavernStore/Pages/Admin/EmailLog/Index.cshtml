@page
@model BrownFlannelTavernStore.Pages.Admin.EmailLog.IndexModel
@using BrownFlannelTavernStore.Models
@using BrownFlannelTavernStore.Utilities
@{
    ViewData["Title"] = "Email Log";

    SortableHeaderViewModel Sortable(string columnKey, string displayName) => new()
    {
        PageName = "/Admin/EmailLog/Index",
        ColumnKey = columnKey,
        DisplayName = displayName,
        CurrentSort = Model.SortBy,
        CurrentDir = Model.SortDir,
        RouteData = Model.BuildRouteData()
    };

    var dateHeader = Sortable(EmailLogSortKeys.Date, "Sent At");
    var recipientHeader = Sortable(EmailLogSortKeys.Recipient, "To");
    var typeHeader = Sortable(EmailLogSortKeys.Type, "Type");
    var subjectHeader = Sortable(EmailLogSortKeys.Subject, "Subject");
    var statusHeader = Sortable(EmailLogSortKeys.Status, "Status");
    var updatedHeader = Sortable(EmailLogSortKeys.Updated, "Updated");
}

<h2>Email Log</h2>
<p class="text-muted">Email send history.</p>

<form method="get" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label small">Status</label>
            <select asp-for="StatusFilter" class="form-select form-select-sm">
                <option value="">All</option>
                @foreach (var s in Enum.GetValues<EmailStatus>())
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small">Type</label>
            <select asp-for="TypeFilter" class="form-select form-select-sm">
                <option value="">All</option>
                @foreach (var t in Enum.GetValues<EmailType>())
                {
                    <option value="@t" selected="@(Model.TypeFilter == t)">@t</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small">Recipient contains</label>
            <input asp-for="RecipientSearchFilter" type="text" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Date from</label>
            <input asp-for="DateFromFilter" type="date" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Date to</label>
            <input asp-for="DateToFilter" type="date" class="form-control form-control-sm" />
        </div>
        <div class="col-md-1">
            <input type="hidden" asp-for="SortBy" />
            <input type="hidden" asp-for="SortDir" />
            <button type="submit" class="btn btn-sm btn-bft">Apply</button>
            <a asp-page="/Admin/EmailLog/Index" class="btn btn-sm btn-outline-bft">Clear</a>
        </div>
    </div>
</form>

@if (Model.EmailLogs.TotalCount == 0)
{
    <p>No emails match the current filters.</p>
}
else
{
    <table class="table table-sm">
        <thead>
            <tr>
                <partial name="_SortableHeader" model="dateHeader" />
                <partial name="_SortableHeader" model="recipientHeader" />
                <partial name="_SortableHeader" model="typeHeader" />
                <partial name="_SortableHeader" model="subjectHeader" />
                <th>Order</th>
                <partial name="_SortableHeader" model="statusHeader" />
                <partial name="_SortableHeader" model="updatedHeader" />
                <th>Provider ID</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.EmailLogs.Items)
            {
                <tr>
                    <td>@log.CreatedAt.ToString("MM/dd/yyyy h:mm tt")</td>
                    <td>@log.ToAddress</td>
                    <td>@log.EmailType</td>
                    <td>@log.Subject</td>
                    <td>
                        @if (log.OrderId.HasValue)
                        {
                            <a asp-page="/Admin/Orders/Details" asp-route-id="@log.OrderId">#@log.OrderId</a>
                        }
                    </td>
                    <td>
                        @switch (log.Status)
                        {
                            case EmailStatus.Delivered:
                                <span class="badge bg-success">Delivered</span>
                                break;
                            case EmailStatus.Sent:
                                <span class="badge bg-secondary" title="Accepted by Resend; awaiting delivery confirmation">Sent</span>
                                break;
                            case EmailStatus.Bounced:
                                <span class="badge bg-danger" title="@log.ErrorMessage">Bounced</span>
                                break;
                            case EmailStatus.Complained:
                                <span class="badge bg-danger" title="Recipient marked as spam">Complained</span>
                                break;
                            case EmailStatus.Failed:
                                <span class="badge bg-danger" title="@log.ErrorMessage">Failed</span>
                                break;
                        }
                    </td>
                    <td>
                        @if (log.DeliveryUpdatedAt.HasValue)
                        {
                            @log.DeliveryUpdatedAt.Value.ToString("MM/dd h:mm tt")
                        }
                    </td>
                    <td><code class="small">@log.ProviderMessageId</code></td>
                </tr>
            }
        </tbody>
    </table>

    <partial name="_Pagination" model="@Model.Pagination" />
}

<a asp-page="/Admin/Index" class="btn btn-outline-bft mt-3">Back to Dashboard</a>
