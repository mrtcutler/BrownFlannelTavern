@page
@model BrownFlannelTavernStore.Pages.Admin.Products.IndexModel
@using BrownFlannelTavernStore.Utilities
@{
    ViewData["Title"] = "Manage Products";

    SortableHeaderViewModel Sortable(string columnKey, string displayName) => new()
    {
        PageName = "/Admin/Products/Index",
        ColumnKey = columnKey,
        DisplayName = displayName,
        CurrentSort = Model.SortBy,
        CurrentDir = Model.SortDir,
        RouteData = Model.BuildRouteData()
    };

    var idHeader = Sortable(ProductsSortKeys.Id, "ID");
    var nameHeader = Sortable(ProductsSortKeys.Name, "Name");
    var categoryHeader = Sortable(ProductsSortKeys.Category, "Category");
    var priceHeader = Sortable(ProductsSortKeys.Price, "Price");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Products</h2>
    <a asp-page="/Admin/Products/Create" class="btn btn-bft">Add Product</a>
</div>

<form method="get" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small">Category</label>
            <select asp-for="CategoryFilter" class="form-select form-select-sm">
                <option value="">All</option>
                @foreach (var category in Model.AvailableCategories)
                {
                    <option value="@category" selected="@(Model.CategoryFilter == category)">@category</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label small">Name contains</label>
            <input asp-for="NameSearchFilter" type="text" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <input type="hidden" asp-for="SortBy" />
            <input type="hidden" asp-for="SortDir" />
            <button type="submit" class="btn btn-sm btn-bft">Apply</button>
            <a asp-page="/Admin/Products/Index" class="btn btn-sm btn-outline-bft">Clear</a>
        </div>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <partial name="_SortableHeader" model="idHeader" />
            <partial name="_SortableHeader" model="nameHeader" />
            <partial name="_SortableHeader" model="categoryHeader" />
            <partial name="_SortableHeader" model="priceHeader" />
            <th>Variants</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model.Products.Items)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Name</td>
                <td>@product.Category</td>
                <td>$@product.Price.ToString("F2")</td>
                <td>@product.Variants.Count</td>
                <td>
                    <a asp-page="/Admin/Products/Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-bft">Edit</a>
                    <a asp-page="/Admin/Products/Delete" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_Pagination" model="@Model.Pagination" />

<a asp-page="/Admin/Index" class="btn btn-outline-bft mt-3">Back to Dashboard</a>
